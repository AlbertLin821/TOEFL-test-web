{
  "name": "toefl-mock-platform",
  "version": "0.1.0",
  "private": true,
  "description": "TOEFL-style four-skill English mock test platform (B2B multi-tenant SaaS). Not affiliated with ETS.",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter grading-worker dev",
    "db:migrate": "pnpm --filter @toefl/database migrate:dev",
    "db:seed": "pnpm --filter @toefl/database seed",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "puppeteer"
    ]
  }
}
