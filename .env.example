# ---- Database ----
DATABASE_URL=postgresql://toefl:toefl_local_dev@localhost:5432/toefl_mock

# ---- Redis / Queue ----
REDIS_URL=redis://localhost:6379

# ---- API server ----
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# ---- Object storage (MinIO locally, S3/R2 in production) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio_local
S3_SECRET_KEY=minio_local_dev
S3_BUCKET_ASSETS=toefl-assets
S3_BUCKET_RECORDINGS=toefl-recordings
S3_BUCKET_REPORTS=toefl-reports
S3_FORCE_PATH_STYLE=true

# ---- Email (Mailpit locally) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@toefl-mock.local
PLATFORM_NAME=TOEFL-style Mock Test Platform

# Optional: custom Chrome/Chromium path for PDF generation worker (Puppeteer).
# If unset, worker falls back to Playwright-installed Chromium when available.
# PUPPETEER_EXECUTABLE_PATH=C:\path\to\chrome.exe

# ---- AI grading ----
# AI_MODE=mock lets the whole flow run without a real OpenAI key.
AI_MODE=mock
OPENAI_API_KEY=sk-your-key-here
OPENAI_GRADING_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_AUDIO_MODEL=gpt-audio-1.5
AI_MAX_RETRIES=3
AI_GRADING_CONCURRENCY=3
AI_TRANSCRIPTION_CONCURRENCY=3

# Browser recordings are converted to mono 16 kHz PCM WAV before OpenAI acoustic analysis.
FFMPEG_PATH=ffmpeg
